{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "types": ["bun"],
    "allowImportingTsExtensions": true
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/test/**/*.ts"]
}
